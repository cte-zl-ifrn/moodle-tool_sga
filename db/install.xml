<?xml version="1.0" encoding="UTF-8" ?>
<XMLDB PATH="local/suap/db" VERSION="2026012200"
       COMMENT="Relatórios consolidados de minicursos autoinstrucionais">

  <TABLES>

    <TABLE NAME="tool_sga_relatorio_cursos_autoinstrucionais" COMMENT="Snapshot de minicursos agrupados por nome do curso e campus">

      <FIELDS>
        <FIELD NAME="id"                  TYPE="int"    LENGTH="10"   NOTNULL="true" SEQUENCE="true"/>
        <FIELD NAME="curso_nome"          TYPE="char"   LENGTH="255"  NOTNULL="true"/>
        <FIELD NAME="campus"              TYPE="char"   LENGTH="255"  NOTNULL="true"/>
        <FIELD NAME="diario_tipo"         TYPE="char"   LENGTH="50"   NOTNULL="true"/>
        <FIELD NAME="quantidade_cursos"   TYPE="int"    LENGTH="10"   NOTNULL="true" DEFAULT="1"/>
        <FIELD NAME="total_enrolled"      TYPE="int"    LENGTH="10"   NOTNULL="true" DEFAULT="0"/>
        <FIELD NAME="accessed"            TYPE="int"    LENGTH="10"   NOTNULL="true" DEFAULT="0"/>
        <FIELD NAME="no_access"           TYPE="int"    LENGTH="10"   NOTNULL="true" DEFAULT="0"/>
        <FIELD NAME="final_exam_takers"   TYPE="int"    LENGTH="10"   NOTNULL="true" DEFAULT="0"/>
        <FIELD NAME="passed"              TYPE="int"    LENGTH="10"   NOTNULL="true" DEFAULT="0"/>
        <FIELD NAME="failed"              TYPE="int"    LENGTH="10"   NOTNULL="true" DEFAULT="0"/>
        <FIELD NAME="avg_grade"           TYPE="number" LENGTH="10"   NOTNULL="true" DEFAULT="0" DECIMALS="2"/>
        <FIELD NAME="with_certificate"    TYPE="int"    LENGTH="10"   NOTNULL="true" DEFAULT="0"/>
        <FIELD NAME="without_certificate" TYPE="int"    LENGTH="10"   NOTNULL="true" DEFAULT="0"/>
        <FIELD NAME="completed"           TYPE="int"    LENGTH="10"   NOTNULL="true" DEFAULT="0"/>
        <FIELD NAME="timecreated"         TYPE="int"    LENGTH="10"   NOTNULL="true"/>
      </FIELDS>

      <KEYS>
        <KEY NAME="primary" TYPE="primary" FIELDS="id"/>
      </KEYS>

      <INDEXES>
        <INDEX NAME="idx_curso_nome"    UNIQUE="false" FIELDS="curso_nome"/>
        <INDEX NAME="idx_campus"        UNIQUE="false" FIELDS="campus"/>
        <INDEX NAME="idx_diario_tipo"   UNIQUE="false" FIELDS="diario_tipo"/>
        <INDEX NAME="idx_timecreated"   UNIQUE="false" FIELDS="timecreated"/>
      </INDEXES>

    </TABLE>

    <TABLE NAME="tool_sga_restricoes_autoinscricao" COMMENT="Snapshot de restrições de autoinscrição em minicursos">
      <FIELDS>
        <FIELD NAME="id"            TYPE="int"  LENGTH="10"     NOTNULL="true" SEQUENCE="true"/>
        <FIELD NAME="courseid"      TYPE="int"  LENGTH="10"     NOTNULL="true"/>
        <FIELD NAME="chave"         TYPE="char" LENGTH="255"    NOTNULL="true"/>
        <FIELD NAME="restricao"     TYPE="char" LENGTH="255"    NOTNULL="true"/>
        <FIELD NAME="descricao"     TYPE="text"/>
        <FIELD NAME="timecreated"   TYPE="int"  LENGTH="10"     NOTNULL="true"/>
      </FIELDS>

      <KEYS>
        <KEY NAME="primary" TYPE="primary" FIELDS="id"/>
      </KEYS>

      <INDEXES>
        <INDEX NAME="idx_courseid"  UNIQUE="false" FIELDS="courseid"  />
        <INDEX NAME="idx_chave"     UNIQUE="false" FIELDS="chave"     />
      </INDEXES>
    </TABLE>

  </TABLES>
</XMLDB>
